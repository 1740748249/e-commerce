<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecommerce.product.mapper.EProductSkuMapper">

    <update id="batchDeductStock">
        UPDATE e_product_sku
        SET stock = stock -
        <foreach collection="items" item="item" open="CASE id " close=" ELSE 0 END">
            WHEN #{item.skuId} THEN #{item.quantity}
        </foreach>
        WHERE id IN
        <foreach collection="items" item="item" open="(" close=")" separator=",">
            #{item.skuId}
        </foreach>
    </update>

    <update id="batchRestoreStock">
        UPDATE e_product_sku
        SET stock = stock +
        <foreach collection="items" item="item" open="CASE id " close=" ELSE 0 END">
            WHEN #{item.skuId} THEN #{item.quantity}
        </foreach>
        WHERE id IN
        <foreach collection="items" item="item" open="(" close=")" separator=",">
            #{item.skuId}
        </foreach>
    </update>

</mapper>
